{
  "rewrites": [
    { "source": "/((?!assets|icons|.*\\.png|.*\\.ico|.*\\.svg|.*\\.webmanifest).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
